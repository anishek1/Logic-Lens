# ── LLM Provider ─────────────────────────────────────────────
# Options: groq | gemini | ollama
LLM_PROVIDER=groq

# Groq (fast, free tier — recommended)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM (recommended — large context, fast inference)
# LLM_PROVIDER=nim
# NIM_API_KEY=nvapi-your_key_here
# NIM_MODEL=meta/llama-3.3-70b-instruct

# Gemini (optional)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here

# Ollama (local, no API key needed)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ── Paths ─────────────────────────────────────────────────────
# Local dev:       ../cloned_repos
# Railway/Docker:  /tmp/cloned_repos  (set via Dockerfile ENV)
REPOS_DIR=../cloned_repos
OUTPUT_DIR=../output

# ── App ───────────────────────────────────────────────────────
DEBUG=false
