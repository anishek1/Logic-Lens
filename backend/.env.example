# ── LLM Provider ─────────────────────────────────────────────
# Options: groq | gemini | ollama
LLM_PROVIDER=groq

# Groq (fast, free tier — recommended)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM — access many models (MiniMax, Llama, Nemotron, Mistral, etc.)
# LLM_PROVIDER=nim
# NIM_API_KEY=nvapi-your_key_here
# NIM_MODEL=minimaxai/minimax-m2.5              # strong general model
# NIM_MODEL=meta/llama-3.3-70b-instruct         # fast, broad coverage
# NIM_MODEL=nvidia/nemotron-3-nano-30b-a3b           # fast hybrid MoE (30B / 3B active), thinking auto-enabled
# NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1   # larger reasoning model, slower but stronger

# Gemini (optional)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here

# Ollama (local, no API key needed)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ── Paths ─────────────────────────────────────────────────────
REPOS_DIR=../cloned_repos

# ── RAG ───────────────────────────────────────────────────────
# ENABLE_RAG=false       disables ChromaDB entirely (saves ~300 MB RAM)
# ENABLE_RERANK=false    skips cross-encoder rerank (faster, lower precision)
# EMBED_MODEL   — bi-encoder for dense retrieval
# RERANK_MODEL  — cross-encoder that rescores the candidate pool
ENABLE_RAG=true
ENABLE_RERANK=true
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ── App ───────────────────────────────────────────────────────
DEBUG=false
